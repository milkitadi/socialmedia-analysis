    <div class="barrow"><div class="blabel"></div><div class="bartrack"><div class="barfill reach" style="width:11.95%"></div></div><div class="bval">11.95%</div></div>

    <div class="barrow"><div class="blabel">Vietnam &amp; Relocation</div><div class="bartrack"><div class="barfill posts" style="width:12.46%"></div></div><div class="bval">12.46%</div></div>
    <div class="barrow"><div class="blabel"></div><div class="bartrack"><div class="barfill reach" style="width:6.32%"></div></div><div class="bval">6.32%</div></div>

    <div class="barrow"><div class="blabel">People of VUS</div><div class="bartrack"><div class="barfill posts" style="width:5.56%"></div></div><div class="bval">5.56%</div></div>
    <div class="barrow"><div class="blabel"></div><div class="bartrack"><div class="barfill reach" style="width:3.74%"></div></div><div class="bval">3.74%</div></div>

    <div class="barrow"><div class="blabel">Other</div><div class="bartrack"><div class="barfill posts" style="width:4.38%"></div></div><div class="bval">4.38%</div></div>
    <div class="barrow"><div class="blabel"></div><div class="bartrack"><div class="barfill reach" style="width:10.46%"></div></div><div class="bval"><b>10.46%</b></div></div>
  </div>

  <h3>Multi-dimensional performance matrix (Reach · Engagement · Link Clicks · Views)</h3>
  <table>
    <thead><tr><th>Pillar</th><th class="num">% Posts</th><th class="num">% Reach</th><th class="num">% Engage</th><th class="num">% Clicks</th><th>Role in the Funnel</th></tr></thead>
    <tbody>
      <tr><td class="name">Teach at VUS</td><td class="num">30.98%</td><td class="num">~30%</td><td class="num">~40%</td><td class="num">51.87%</td><td><span class="tag over">🎯 Conversion</span></td></tr>
